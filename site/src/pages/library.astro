<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <meta
      name="description"
      content="The Gokigen Time Library — books by Flavia Nishimura about food, gardens and slow living."
    />

    <title>Library | GO・KI・GEN TIME</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Inter:wght@300;400&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --cream: #faf8f3;
        --paper: #f8f5ef;
        --ink: #4a433c;
        --muted: #766f68;
        --line: #ddd6cc;
        --accent: #a5564d;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--cream);
        color: var(--ink);
        font-family: "Inter", sans-serif;
        font-weight: 300;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 24px 46px;
        background: rgba(250, 248, 243, 0.94);
        border-bottom: 1px solid var(--line);
        backdrop-filter: blur(12px);
      }

      .logo {
        font-family: "Cormorant Garamond", serif;
        font-size: 22px;
        letter-spacing: 0.18em;
      }

      .menu {
        display: flex;
        align-items: center;
        gap: 32px;
        white-space: nowrap;
      }

      .menu a {
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .menu a:hover {
        color: var(--accent);
      }

      .hero {
        min-height: 62vh;
        display: flex;
        align-items: center;
        padding: 90px 8vw 70px;
        border-bottom: 1px solid var(--line);
      }

      .hero-inner {
        width: min(1180px, 100%);
        margin: 0 auto;
      }

      .eyebrow {
        margin-bottom: 24px;
        font-size: 11px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .hero h1 {
        max-width: 900px;
        margin: 0;
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(68px, 10vw, 150px);
        font-weight: 300;
        line-height: 0.82;
      }

      .hero-text {
        max-width: 520px;
        margin: 42px 0 0;
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(25px, 3vw, 38px);
        line-height: 1.15;
      }

      .books {
        padding: 110px 8vw 130px;
      }

      .books-inner {
        width: min(1180px, 100%);
        margin: 0 auto;
      }

      .section-label {
        margin-bottom: 18px;
        font-size: 11px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .section-title {
        margin: 0 0 60px;
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(52px, 7vw, 92px);
        font-weight: 300;
        line-height: 0.9;
      }

      .book-card {
        display: grid;
        grid-template-columns: minmax(260px, 0.85fr) minmax(320px, 1.15fr);
        border: 1px solid var(--line);
        background: var(--paper);
      }

      .book-cover-placeholder {
        min-height: 590px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 50px;
        border-right: 1px solid var(--line);
        text-align: center;
      }

      .cover-inner {
        width: min(310px, 100%);
        aspect-ratio: 0.72;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 42px 28px;
        border: 1px solid var(--ink);
      }

      .cover-small {
        font-size: 9px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
      }

      .cover-title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(42px, 5vw, 65px);
        font-weight: 300;
        line-height: 0.88;
      }

      .cover-japanese {
        font-size: 17px;
        line-height: 1.7;
      }

      .book-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: clamp(42px, 7vw, 90px);
      }

      .book-edition {
        margin-bottom: 25px;
        font-size: 10px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .book-content h2 {
        margin: 0;
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(58px, 7vw, 100px);
        font-weight: 300;
        line-height: 0.82;
      }

      .book-title-japanese {
        margin-top: 26px;
        font-size: 22px;
        line-height: 1.6;
      }

      .book-description {
        max-width: 580px;
        margin: 38px 0;
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(22px, 2.5vw, 31px);
        line-height: 1.25;
      }

      .book-meta {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
        margin-bottom: 40px;
        padding-top: 30px;
        border-top: 1px solid var(--line);
      }

      .meta-label {
        display: block;
        margin-bottom: 8px;
        font-size: 9px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .meta-value {
        font-size: 13px;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 50px;
        padding: 0 28px;
        border: 1px solid var(--ink);
        font-size: 10px;
        letter-spacing: 0.17em;
        text-transform: uppercase;
        transition: 0.2s ease;
      }

      .button-primary {
        background: var(--ink);
        color: var(--cream);
      }

      .button:hover {
        background: var(--accent);
        border-color: var(--accent);
        color: white;
      }

      footer {
        display: flex;
        justify-content: space-between;
        gap: 24px;
        padding: 30px 46px;
        border-top: 1px solid var(--line);
        font-size: 10px;
        letter-spacing: 0.12em;
      }

      @media (max-width: 820px) {
        .site-header {
          padding: 20px;
        }

        .menu {
          gap: 15px;
        }

        .menu a {
          font-size: 9px;
        }

        .hero,
        .books {
          padding-left: 24px;
          padding-right: 24px;
        }

        .book-card {
          grid-template-columns: 1fr;
        }

        .book-cover-placeholder {
          min-height: 480px;
          border-right: 0;
          border-bottom: 1px solid var(--line);
        }

        .book-meta {
          grid-template-columns: 1fr;
          gap: 16px;
        }

        footer {
          flex-direction: column;
          padding: 28px 24px;
        }
      }
    </style>
  </head>

  <body>
    <header class="site-header">
      <a class="logo" href="/">GO・KI・GEN</a>

      <nav class="menu">
        <a href="/">Home</a>
        <a href="/library">Library</a>
        <a href="/ja">日本語</a>
        <a href="/">Português</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-inner">
          <div class="eyebrow">The Gokigen Time Library</div>

          <h1>
            Books made<br />
            to be kept
          </h1>

          <p class="hero-text">
            One book at a time, created with care, intention and a quiet sense
            of beauty.
          </p>
        </div>
      </section>

      <section class="books">
        <div class="books-inner">
          <div class="section-label">First edition</div>

          <h2 class="section-title">
            The first book
          </h2>

          <article class="book-card">
            <div class="book-cover-placeholder">
              <div class="cover-inner">
                <div class="cover-small">GO・KI・GEN TIME</div>

                <div class="cover-title">
                  Desserts<br />
                  for One
                </div>

                <div class="cover-japanese">
                  一人のための<br />
                  小さなお菓子
                </div>

                <div class="cover-small">Flavia Nishimura</div>
              </div>
            </div>

            <div class="book-content">
              <div class="book-edition">
                Japanese edition
              </div>

              <h2>
                Desserts<br />
                for One
              </h2>

              <div class="book-title-japanese">
                一人のための小さなお菓子
              </div>

              <p class="book-description">
                An intimate collection of elegant single-serving desserts,
                created for quiet afternoons, small kitchens and the pleasure
                of making something beautiful just for yourself.
              </p>

              <div class="book-meta">
                <div>
                  <span class="meta-label">Language</span>
                  <span class="meta-value">Japanese</span>
                </div>

                <div>
                  <span class="meta-label">Format</span>
                  <span class="meta-value">Digital book</span>
                </div>

                <div>
                  <span class="meta-label">Status</span>
                  <span class="meta-value">Coming soon</span>
                </div>
              </div>

              <div class="actions">
                <a
                  class="button button-primary"
                  href="/books/desserts-for-one"
                >
                  View the book
                </a>

                <a class="button" href="/ja">
                  日本語
                </a>
              </div>
            </div>
          </article>
        </div>
      </section>
    </main>

    <footer>
      <span>GO・KI・GEN TIME</span>
      <span>Created in Tainai, Japan</span>
      <span>© 2026 Flavia Nishimura</span>
    </footer>
  </body>
</html>