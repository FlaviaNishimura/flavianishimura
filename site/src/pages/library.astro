---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <meta
      name="description"
      content="The Gokigen Time Library — books by Flavia Nishimura about food, gardens, seasons and slow living."
    />

    <title>Library | GO • KI • GEN TIME</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --cream: #faf8f3;
        --paper: #f8f5ef;
        --ink: #4a433c;
        --muted: #766f68;
        --line: #ddd6cc;
        --accent: #a56a4d;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--cream);
        color: var(--ink);
        font-family: "Inter", sans-serif;
        font-weight: 300;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .site-header {
        position: fixed;
        z-index: 100;
        top: 0;
        right: 0;
        left: 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 24px 46px;
        background: rgba(250, 248, 243, 0.92);
        border-bottom: 1px solid var(--line);
        backdrop-filter: blur(12px);
      }

      .logo {
        font-family: "Cormorant Garamond", serif;
        font-size: 22px;
        letter-spacing: 0.18em;
      }

      .menu {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 36px;
        white-space: nowrap;
      }

      .menu a {
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .menu a:hover {
        color: var(--accent);
      }

      .hero {
        min-height: 72vh;
        display: flex;
        align-items: flex-end;
        padding: 150px 46px 90px;
        border-bottom: 1px solid var(--line);
      }

      .hero-inner {
        width: min(100%, 1180px);
        margin: 0 auto;
      }

      .eyebrow {
        margin-bottom: 22px;
        font-size: 11px;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--accent);
      }

      h1 {
        max-width: 850px;
        margin: 0;
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(70px, 10vw, 140px);
        font-weight: 400;
        line-height: 0.84;
      }

      .hero-text {
        max-width: 600px;
        margin-top: 44px;
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(23px, 3vw, 34px);
        line-height: 1.4;
      }

      .manifesto {
        padding: 110px 46px;
        border-bottom: 1px solid var(--line);
      }

      .manifesto-inner {
        width: min(100%, 1180px);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 0.45fr 1fr;
        gap: 80px;
      }

      .manifesto-label {
        font-size: 11px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .manifesto-text {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(38px, 5vw, 70px);
        line-height: 1.05;
      }

      .books {
        padding: 120px 46px;
      }

      .books-inner {
        width: min(100%, 1180px);
        margin: 0 auto;
      }

      .section-label {
        font-size: 11px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .book {
        display: grid;
        grid-template-columns: 0.85fr 1.15fr;
        gap: 80px;
        align-items: center;
        margin-top: 60px;
        padding-top: 60px;
        border-top: 1px solid var(--line);
      }

      .book-cover {
        aspect-ratio: 4 / 5;
        display: grid;
        place-items: center;
        padding: 40px;
        background: var(--paper);
        border: 1px solid var(--line);
        text-align: center;
      }

      .book-cover-small {
        margin-bottom: 26px;
        font-size: 10px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .book-cover-title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(38px, 5vw, 64px);
        line-height: 1;
      }

      .book-cover-japanese {
        margin-top: 28px;
        font-size: 19px;
        line-height: 1.8;
        letter-spacing: 0.08em;
      }

      .book-number {
        font-size: 11px;
        letter-spacing: 0.2em;
        color: var(--accent);
      }

      .book-title {
        margin: 20px 0 0;
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(52px, 7vw, 92px);
        font-weight: 400;
        line-height: 0.9;
      }

      .book-title-japanese {
        margin-top: 24px;
        font-size: 21px;
        letter-spacing: 0.08em;
      }

      .book-description {
        max-width: 620px;
        margin-top: 34px;
        font-family: "Cormorant Garamond", serif;
        font-size: 25px;
        line-height: 1.5;
      }

      .book-meta {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
        margin-top: 42px;
        padding-top: 28px;
        border-top: 1px solid var(--line);
      }

      .meta-label {
        margin-bottom: 9px;
        font-size: 9px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .meta-value {
        font-size: 13px;
        line-height: 1.6;
      }

      .actions {
        display: flex;
        gap: 14px;
        margin-top: 44px;
      }

      .button {
        display: inline-block;
        min-width: 190px;
        padding: 16px 24px;
        border: 1px solid var(--ink);
        font-size: 11px;
        letter-spacing: 0.16em;
        text-align: center;
        text-transform: uppercase;
        transition: 0.25s ease;
      }

      .button-primary {
        background: var(--ink);
        color: var(--paper);
      }

      .button:hover {
        background: var(--accent);
        border-color: var(--accent);
        color: white;
      }

      .future {
        margin-top: 130px;
        padding-top: 70px;
        border-top: 1px solid var(--line);
      }

      .future-title {
        margin: 18px 0 0;
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(44px, 6vw, 78px);
        font-weight: 400;
      }

      .future-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 50px;
      }

      .future-card {
        min-height: 260px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 28px;
        background: var(--paper);
        border: 1px solid var(--line);
      }

      .future-card-label {
        font-size: 10px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent);
      }

      .future-card-title {
        margin-top: 16px;
        font-family: "Cormorant Garamond", serif;
        font-size: 32px;
        line-height: 1;
      }

      footer {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        padding: 32px 46px;
        border-top: 1px solid var(--line);
        font-size: 10px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--muted);
      }

      @media (max-width: 850px) {
        .site-header {
          padding: 20px 22px;
        }

        .menu {
          display: none;
        }

        .hero {
          min-height: 65vh;
          padding: 130px 22px 70px;
        }

        .manifesto,
        .books {
          padding-right: 22px;
          padding-left: 22px;
        }

        .manifesto-inner,
        .book {
          grid-template-columns: 1fr;
          gap: 40px;
        }

        .book-meta,
        .future-grid {
          grid-template-columns: 1fr;
        }

        .actions {
          flex-direction: column;
        }

        .button {
          width: 100%;
        }

        footer {
          flex-direction: column;
          padding: 28px 22px;
        }
      }
    </style>
  </head>

  <body>
    <header class="site-header">
      <a class="logo" href="/">GO • KI • GEN</a>

      <nav class="menu">
        <a href="/">Home</a>
        <a href="/library">Library</a>
        <a href="/ja">日本語</a>
        <a href="/pt">Português</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-inner">
          <div class="eyebrow">The Gokigen Time Library</div>

          <h1>Books made to be kept</h1>

          <div class="hero-text">
            Every book begins with a season, a place and a quiet idea
          </div>
        </div>
      </section>

      <section class="manifesto">
        <div class="manifesto-inner">
          <div class="manifesto-label">A growing library</div>

          <div class="manifesto-text">
            Growing.<br />
            Baking.<br />
            Writing.<br />
            Photographing.<br />
            Collecting stories.<br />
            Always creating.
          </div>
        </div>
      </section>

      <section class="books">
        <div class="books-inner">
          <div class="section-label">Current title</div>

          <article class="book">
            <div class="book-cover">
              <div>
                <div class="book-cover-small">First edition</div>

                <div class="book-cover-title">
                  Desserts<br />
                  for One
                </div>

                <div class="book-cover-japanese">
                  一人のための<br />
                  小さなお菓子
                </div>
              </div>
            </div>

            <div class="book-content">
              <div class="book-number">Book 01</div>

              <h2 class="book-title">
                Desserts<br />
                for One
              </h2>

              <div class="book-title-japanese">
                一人のための小さなお菓子
              </div>

              <div class="book-description">
                An intimate collection of elegant single-serving desserts,
                created for quiet afternoons, small kitchens and the pleasure
                of making something beautiful just for yourself.
              </div>

              <div class="book-meta">
                <div>
                  <div class="meta-label">Languages</div>
                  <div class="meta-value">Japanese<br />Portuguese</div>
                </div>

                <div>
                  <div class="meta-label">Format</div>
                  <div class="meta-value">Digital book<br />QR video lessons</div>
                </div>

                <div>
                  <div class="meta-label">Status</div>
                  <div class="meta-value">Coming soon<br />2026</div>
                </div>
              </div>

              <div class="actions">
                <a class="button button-primary" href="/books/desserts-for-one">
                  View the book
                </a>

                <a class="button" href="/ja">
                  日本語
                </a>
              </div>
            </div>
          </article>

          <section class="future">
            <div class="section-label">Future volumes</div>

            <h2 class="future-title">The library continues</h2>

            <div class="future-grid">
              <div class="future-card">
                <div class="future-card-label">In development</div>

                <div class="future-card-title">
                  Kuma<br />
                  Garden
                </div>
              </div>

              <div class="future-card">
                <div class="future-card-label">Future edition</div>

                <div class="future-card-title">
                  Bread<br />
                  for One
                </div>
              </div>

              <div class="future-card">
                <div class="future-card-label">Living archive</div>

                <div class="future-card-title">
                  Seasonal<br />
                  Stories
                </div>
              </div>
            </div>
          </section>
        </div>
      </section>
    </main>

    <footer>
      <span>GO • KI • GEN TIME</span>
      <span>Created in Tainai, Japan</span>
      <span>© 2026 Flavia Nishimura</span>
    </footer>
  </body>
</html>